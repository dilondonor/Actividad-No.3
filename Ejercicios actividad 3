# EJERCICIO 8.3

import ipywidgets as widgets
from IPython.display import display, clear_output
import math

class FiguraGeometrica:
    def __init__(self):
        self.volumen = 0.0
        self.superficie = 0.0
    def setVolumen(self, volumen): self.volumen = volumen
    def setSuperficie(self, superficie): self.superficie = superficie
    def getVolumen(self): return self.volumen
    def getSuperficie(self): return self.superficie

class Cilindro(FiguraGeometrica):
    def __init__(self, radio, altura):
        super().__init__()
        self.radio, self.altura = radio, altura
        self.setVolumen(self.calcularVolumen())
        self.setSuperficie(self.calcularSuperficie())
    def calcularVolumen(self): return math.pi * self.altura * math.pow(self.radio, 2.0)
    def calcularSuperficie(self):
        return (2.0 * math.pi * self.radio * self.altura) + (2.0 * math.pi * math.pow(self.radio, 2.0))

class Esfera(FiguraGeometrica):
    def __init__(self, radio):
        super().__init__()
        self.radio = radio
        self.setVolumen(self.calcularVolumen())
        self.setSuperficie(self.calcularSuperficie())
    def calcularVolumen(self): return 1.333 * math.pi * math.pow(self.radio, 3.0)
    def calcularSuperficie(self): return 4.0 * math.pi * math.pow(self.radio, 2.0)

class Piramide(FiguraGeometrica):
    def __init__(self, base, altura, apotema):
        super().__init__()
        self.base, self.altura, self.apotema = base, altura, apotema
        self.setVolumen(self.calcularVolumen())
        self.setSuperficie(self.calcularSuperficie())
    def calcularVolumen(self): return (math.pow(self.base, 2.0) * self.altura) / 3.0
    def calcularSuperficie(self): return math.pow(self.base, 2.0) + (2.0 * self.base * self.apotema)

class VentanaCilindro:
    def __init__(self):
        self.inicio()
    def inicio(self):
        self.campoRadio = widgets.FloatText(description="Radio:", value=None)
        self.campoAltura = widgets.FloatText(description="Altura:", value=None)
        self.calcular = widgets.Button(description="Calcular")
        self.volumen = widgets.Label(value="Volumen (cm3):")
        self.superficie = widgets.Label(value="Superficie (cm2):")
        self.calcular.on_click(self.actionPerformed)
        self.contenedor = widgets.VBox([widgets.HTML("<b>Cilindro</b>"), self.campoRadio, self.campoAltura, self.calcular, self.volumen, self.superficie])
    def actionPerformed(self, _):
        try:
            cil = Cilindro(float(self.campoRadio.value), float(self.campoAltura.value))
            self.volumen.value, self.superficie.value = f"Volumen (cm3): {cil.getVolumen():.2f}", f"Superficie (cm2): {cil.getSuperficie():.2f}"
        except: print("Error en datos")

